{
  "name": "audwihr",
  "private": true,
  "version": "0.18.3",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "fetch-data": "node scripts/fetch-data.js",
    "fetch-data:dry": "node scripts/fetch-data.js --dry-run",
    "fetch-data:fresh": "node scripts/fetch-data.js --fresh",
    "fetch-odds": "node scripts/fetch-odds.js",
    "fetch-odds:dry": "node scripts/fetch-odds.js --dry-run",
    "fetch-odds:fresh": "node scripts/fetch-odds.js --fresh",
    "prebuild": "node scripts/fetch-data.js --ci && node scripts/fetch-odds.js --ci",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "validate": "npm run lint && npm run test:run && npm audit",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.{js,jsx}": [
      "eslint --max-warnings=0"
    ]
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^7.13.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^4.1.0",
    "cheerio": "^1.2.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.0",
    "lint-staged": "^16.4.0",
    "vite": "^6.4.1",
    "vitest": "^4.1.0"
  }
}
