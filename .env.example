# ── Audwihr environment variables ──────────────────────────────────────────────
# Copy this file to .env and fill in real values.
# .env is gitignored — never commit real keys.

# The Odds API key for live sportsbook moneylines (Phase 7).
# Free tier: 500 requests/month. Get a key at https://the-odds-api.com
# If absent or set to 'your_key_here', useOdds degrades silently (no sportsbook data).
VITE_ODDS_API_KEY=your_key_here

# Kalshi REST API key for live prediction market prices (Phase 7).
# Free API key: https://trading-api.kalshi.com — requires account creation.
# If absent or set to 'your_key_here', useKalshi degrades silently (no Kalshi data).
# Polymarket CLOB API requires NO key for read-only access.
VITE_KALSHI_API_KEY=your_key_here
